# Estructuras de datos globales (Diccionarios como contenedores principales)
clientes = {}
productos = {}
pedidos = {}

# 1. Registro de Clientes
def register_client(c_id, name, email):
    # Retorna un diccionario con los datos del cliente
    return {
        "nombre": name,
        "correo": email
    }

# 2. Registro de Productos
def register_product(p_id, name, price):
    # La información debe almacenarse en una tupla (id, nombre, precio)
    return (p_id, name, price)

# 3. Creación de Pedidos
def create_order(c_id, p_id, quantity):
    # Obtenemos la tupla del producto para sacar el precio unitario
    product_data = productos[p_id]
    unit_price = product_data[2] # El precio es el tercer elemento de la tupla
    
    total_pedido = unit_price * quantity # Cálculo automático
    
    return {
        "client_id": c_id,
        "product_id": p_id,
        "quantity": quantity,
        "total": total_pedido
    }

# 4. Consulta de Pedidos
def orders():
    if not pedidos:
        return "No hay pedidos registrados."
    
    report = ""
    for o_id, data in pedidos.items():
        client_name = clientes[data["client_id"]]["nombre"]
        product_name = productos[data["product_id"]][1] # Nombre desde la tupla
        report += f"Pedido #{o_id} | Cliente: {client_name} | Producto: {product_name} | Total: ${data['total']}\n"
    return report

# 5. Cálculo de Ingresos y Reporte Final
def calculate_total():
    total = 0.0
    for order in pedidos.values():
        total += order["total"]
    return total

def menu_principal(): 
    while True:
        print("\n--- Sistema de Gestión de Pedidos ---")
        print("1. Registro de clientes")
        print("2. Registro de productos")
        print("3. Creación de pedidos")
        print("4. Consulta de pedidos")
        print("5. Reporte Final y Salir")

        option = input("Ingrese la opción deseada: ")

        if option == "1":
            c_id = int(input("ID del cliente: "))
            if c_id in clientes:
                print("El ID ya existe.")
            else:
                nom = input("Nombre: ")
                cor = input("Correo: ")
                clientes[c_id] = register_client(c_id, nom, cor)
                print("¡Cliente registrado!")

        elif option == "2":
            p_id = int(input("ID del producto: "))
            nom_p = input("Nombre del producto: ")
            pre = float(input("Precio unitario: "))
            productos[p_id] = register_product(p_id, nom_p, pre)
            print(f"Producto registrado: {productos[p_id]}")

        elif option == "3":
            c_id = int(input("ID del cliente para el pedido: "))
            p_id = int(input("ID del producto: "))
            
            if c_id in clientes and p_id in productos:
                cant = int(input("Cantidad: "))
                order_id = len(pedidos) + 1
                pedidos[order_id] = create_order(c_id, p_id, cant)
                print(f"¡Pedido #{order_id} creado con éxito!")
            else:
                print("Error: Cliente o Producto no encontrado.")

        elif option == "4":
            print("\n Listado de Pedidos ")
            print(orders())

        elif option == "5":
            total_ingresos = calculate_total()
            print("\n REPORTE FINAL DE LA JORNADA")
            print(f"Total de pedidos: {len(pedidos)}")
            print(f"Ingresos totales: ${total_ingresos}")
            print("Saliendo del sistema.")
            break

if __name__ == "__main__":
    menu_principal() 
