# MAIN PROGRAM (interfaz de usuario)
# =============================================
if __name__ == "__main__":
    print("=== Sistema de Gestión de Pedidos de Clientes - <Riwi> ===")
    print("Desarrollado según todas las restricciones del desafío.")
    
    clients = {}
    products = {}
    orders = {}
    
    while True:
        print("\n--- MENÚ ---")
        print("1. Registrar Cliente")
        print("2. Registrar Producto")
        print("3. Crear Pedido")
        print("4. Consultar Pedidos Registrados")
        print("5. Calcular Ingresos del Día")
        print("6. Generar Reporte Final y Salir")
        option = input("Seleccione una opción (1-6): ").strip()
        
        if option == "1":
            # Module 1
            client_id = get_next_id(clients)
            name = input("Nombre del cliente: ").strip()
            email = input("Correo electrónico: ").strip()
            clients = register_client(clients, client_id, name, email)
            print(f"✅ Cliente registrado con ID: {client_id}")
        
        elif option == "2":
            # Module 2
            product_id = get_next_id(products)
            name = input("Nombre del producto: ").strip()
            try:
                unit_price = float(input("Precio unitario: "))
                products = register_product(products, product_id, name, unit_price)
                print(f"✅ Producto registrado con ID: {product_id}")
            except ValueError:
                print("❌ Precio inválido.")
        
        elif option == "3":
            # Module 3
            if not clients or not products:
                print("❌ Debe registrar al menos un cliente y un producto primero.")
                continue
            order_id = get_next_id(orders)
            
            # Mostrar clientes y productos disponibles (impresión en main)
            print("\nClientes disponibles:")
            for cid, cdata in clients.items():
                print(f"  ID {cid}: {cdata['name']} ({cdata['email']})")
            print("\nProductos disponibles:")
            for pid, pinfo in products.items():
                name, price = pinfo
                print(f"  ID {pid}: {name} (${price:.2f})")
            
            try:
                client_id = int(input("\nID del cliente: "))
                product_id = int(input("ID del producto: "))
                quantity = int(input("Cantidad: "))
                orders = create_order(orders, products, order_id, client_id, product_id, quantity)
                print(f"✅ Pedido creado con ID: {order_id}")
            except ValueError:
                print("❌ Datos inválidos.")
        
        elif option == "4":
            # Module 4
            orders_data = get_registered_orders(orders, clients, products)
            if not orders_data:
                print("No hay pedidos registrados.")
                continue
            print("\n=== PEDIDOS REGISTRADOS ===")
            for oid, odata in orders_data.items():
                c_name = clients.get(odata["client_id"], {}).get("name", "Desconocido")
                p_info = products.get(odata["product_id"], ("Desconocido", 0))
                p_name = p_info[0]
                print(f"Pedido {oid} | Cliente: {c_name} | Producto: {p_name} | "
                      f"Cant: {odata['quantity']} | Total: ${odata['total']:.2f}")
        
        elif option == "5":
            # Module 5
            income = calculate_daily_income(orders)
            print(f"\nIngresos del día: ${income:.2f}")
        
        elif option == "6":
            # Module 6 + Salida
            if not orders:
                print("No hay pedidos para generar reporte.")
            else:
                report = generate_final_report(orders, clients, products)
                print("\n" + "="*60)
                print("=== REPORTE FINAL DE LA JORNADA ===")
                print("="*60)
                print(f"Total de pedidos registrados: {report['total_orders']}")
                print(f"Total de ingresos generados: ${report['total_income']:.2f}")
                
                print("\nPedidos agrupados por cliente:")
                for cid, group in report["client_groups"].items():
                    print(f"\nCliente ID {cid} - {group['name']}")
                    print(f"  Pedidos: {group['order_count']} | Total gastado: ${group['total_spent']:.2f}")
                    print("  Detalle de pedidos:")
                    for oid, odet in group["orders"].items():
                        p_name = products.get(odet["product_id"], ("Desconocido", 0))[0]
                        print(f"    Pedido {oid}: {p_name} x {odet['quantity']} = ${odet['total']:.2f}")
                
                print("\nProductos vendidos durante el día:")
                for pid, qty in report["product_sales"].items():
                    p_name = products.get(pid, ("Desconocido", 0))[0]
                    print(f"  {p_name} (ID {pid}): {qty} unidades")
                
                print("\n" + "="*60)
            
            print("¡Gracias por usar el sistema! Saliendo...")
            break
        
        else:
            print("❌ Opción inválida.")
