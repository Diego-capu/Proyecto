def get_next_id(current_dict: dict) -> int:
    """
    Returns the next available unique ID.
    
    Parameters:
        current_dict (dict): The current dictionary (clients, products or orders).
    
    Returns:
        int: Next ID (starts at 1 if empty, otherwise max key + 1).
    """
    if not current_dict:
        return 1
    return max(current_dict.keys()) + 1


# =============================================
# Module 1: Client Registration
# =============================================
def register_client(clients: dict, client_id: int, name: str, email: str) -> dict:
    """
    Registers a new client.
    
    Parameters:
        clients (dict): Current clients dictionary.
        client_id (int): Unique client ID.
        name (str): Client name.
        email (str): Client email.
    
    Returns:
        dict: Updated clients dictionary.
    """
    clients[client_id] = {"name": name, "email": email}
    return clients


# =============================================
# Module 2: Product Registration
# =============================================
def register_product(products: dict, product_id: int, name: str, unit_price: float) -> dict:
    """
    Registers a new product using a tuple (immutable).
    
    Parameters:
        products (dict): Current products dictionary.
        product_id (int): Unique product ID.
        name (str): Product name.
        unit_price (float): Unit price.
    
    Returns:
        dict: Updated products dictionary (value is a tuple).
    """
    products[product_id] = (name, unit_price)
    return products


# =============================================
# Module 3: Order Creation
# =============================================
def create_order(orders: dict, products: dict, order_id: int, client_id: int, product_id: int, quantity: int) -> dict:
    """
    Creates a new order and automatically calculates the total.
    Uses product tuple to get unit_price.
    
    Parameters:
        orders (dict): Current orders dictionary.
        products (dict): Products dictionary (for price lookup).
        order_id (int): Unique order ID.
        client_id (int): Client ID.
        product_id (int): Product ID.
        quantity (int): Quantity purchased.
    
    Returns:
        dict: Updated orders dictionary.
    """
    if product_id not in products:
        # Invalid product (in production would handle error, but per spec we assume valid input)
        return orders
    
    _, unit_price = products[product_id]
    total = unit_price * quantity
    
    orders[order_id] = {
        "client_id": client_id,
        "product_id": product_id,
        "quantity": quantity,
        "total": total
    }
    return orders


# =============================================
# Module 4: Consult Registered Orders
# =============================================
def get_registered_orders(orders: dict, clients: dict, products: dict) -> dict:
    """
    Returns the orders dictionary ready for display.
    
    Parameters:
        orders (dict): Current orders.
        clients (dict): Clients (for lookup).
        products (dict): Products (for lookup).
    
    Returns:
        dict: The orders dictionary (main will display it).
    """
    return orders


# =============================================
# Module 5: Daily Income Calculation
# =============================================
def calculate_daily_income(orders: dict) -> float:
    """
    Calculates total income from all registered orders.
    
    Parameters:
        orders (dict): Current orders dictionary.
    
    Returns:
        float: Total income of the day.
    """
    total_income = 0.0
    for order_data in orders.values():
        total_income += order_data["total"]
    return total_income


# =============================================
# Module 6: Final Report Generation
# =============================================
def generate_final_report(orders: dict, clients: dict, products: dict) -> dict:
    """
    Generates the complete final report using only dictionaries and tuples.
    Includes:
      - Total orders
      - Total income
      - Orders grouped by client (nested dict)
      - Products sold (qty per product)
    
    Parameters:
        orders (dict): Current orders.
        clients (dict): Clients.
        products (dict): Products.
    
    Returns:
        dict: Complete report structure.
    """
    report = {
        "total_orders": len(orders),
        "total_income": calculate_daily_income(orders),
        "client_groups": {},
        "product_sales": {}
    }
    
    # Group orders by client (using nested dictionary - no lists)
    for order_id, order_data in orders.items():
        cid = order_data["client_id"]
        if cid not in report["client_groups"]:
            client_name = clients.get(cid, {}).get("name", "Unknown")
            report["client_groups"][cid] = {
                "name": client_name,
                "total_spent": 0.0,
                "order_count": 0,
                "orders": {}  # sub-dictionary for orders
            }
        
        report["client_groups"][cid]["total_spent"] += order_data["total"]
        report["client_groups"][cid]["order_count"] += 1
        report["client_groups"][cid]["orders"][order_id] = {
            "product_id": order_data["product_id"],
            "quantity": order_data["quantity"],
            "total": order_data["total"]
        }
    
    # Products sold during the day
    for order_data in orders.values():
        pid = order_data["product_id"]
        if pid not in report["product_sales"]:
            report["product_sales"][pid] = 0
        report["product_sales"][pid] += order_data["quantity"]
    
    return report


